# Configuração de caminhos para o sistema de organização de termos
# Copie este arquivo para .env e preencha com seus caminhos locais

# Pasta onde estão os arquivos PDF de entrada
PASTA_ENTRADA=C:\Caminho\Para\Pasta\Entrada

# Pasta de destino para termos de ativos
PASTA_DESTINO_ATIVOS=C:\Caminho\Para\DEPARTAMENTOS

# Pasta de destino para termos de SI
PASTA_DESTINO_SI=C:\Caminho\Para\SI

# Pasta para backup dos termos
PASTA_BACKUP=C:\Caminho\Para\Backup_Termos